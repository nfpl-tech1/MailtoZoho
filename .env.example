# Server Configuration
PORT=3000
NODE_ENV=development

# =============================================================================
# Google OAuth2 Credentials (from credentials.json)
# =============================================================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost

# =============================================================================
# Google OAuth2 Tokens (from token.json)
# =============================================================================
GOOGLE_ACCESS_TOKEN=your_access_token
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token

# =============================================================================
# Zoho Creator Configuration
# =============================================================================
# Get these from Zoho API Console (https://api-console.zoho.in)
# Click on your Self Client to get Client ID and Client Secret
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret

# Generate refresh token:
# 1. In Self Client, go to "Generate Code" tab
# 2. Enter scope: ZohoCreator.record.CREATE,ZohoCreator.record.READ
# 3. Set time duration and description
# 4. Click "Create" to get authorization code
# 5. Use the code to generate refresh token via API
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# Your Zoho Creator app details
# Account owner: Your Zoho account email or organization name
ZOHO_ACCOUNT_OWNER=your_account_owner

# App link name: Found in your Zoho Creator app URL
# e.g., if URL is https://creator.zoho.in/your_account/my-app then app link name is "my-app"
ZOHO_APP_LINK_NAME=your_app_link_name

# Form link name: The form where records will be created
ZOHO_FORM_LINK_NAME=Sample_TBD31110

# Report link name for Job lookup (used to find record IDs for lookup fields)
# Usually the form name followed by _Report, e.g., Book_Pre_Alert_Report
ZOHO_JOB_REPORT_LINK_NAME=ERP_Data_Report

# Zoho domains (use .in for India, .com for US, .eu for EU, etc.)
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.in
ZOHO_CREATOR_DOMAIN=https://creator.zoho.in

# =============================================================================
# Email Processing Configuration (IRN-DRN Tracker)
# =============================================================================
# Keywords to search in email subject (comma-separated for multiple)
EMAIL_SUBJECT_KEYWORDS=Document upload confirmation

# How far back to look for emails (in hours)
EMAIL_HOURS_BACK=24

# Maximum number of emails to process
EMAIL_MAX_RESULTS=20

# Auto-push to Zoho (true/false)
ZOHO_PUSH_ENABLED=true

# =============================================================================
# Record Query Configuration
# =============================================================================
# Subject keyword for Record Query emails
RECORD_QUERY_SUBJECT_KEYWORD=Outbound file generated

# How far back to look for Record Query emails (in hours)
RECORD_QUERY_HOURS_BACK=24

# Maximum number of emails to process for Record Query
RECORD_QUERY_MAX_RESULTS=10

# Zoho form name for Record Query
RECORD_QUERY_FORM_LINK_NAME=Record_query

# Zoho report name to lookup Job by BE Number
RECORD_QUERY_JOB_REPORT_LINK_NAME=View_All_Jobs

# Auto-push to Zoho for Record Query (true/false)
RECORD_QUERY_PUSH_ENABLED=true

# =============================================================================
# Vercel Cron Job Security
# =============================================================================
# Secret to protect cron endpoint (generate a random string)
CRON_SECRET=your_random_secret_here

# =============================================================================
# Error Notification Configuration
# =============================================================================
# Comma-separated email addresses to receive error notifications
# Example: admin@example.com,dev@example.com
ERROR_NOTIFICATION_EMAILS=your_email@example.com

# =============================================================================
# Security Configuration
# =============================================================================
# Password to access settings page (leave empty to disable authentication)
SETTINGS_PASSWORD=your_secure_password
